# ==============================
# KAFKA CONFIGURATION
# ==============================

# Kafka brokers inside Docker network
KAFKA_BROKERS=kafka:9092
# ==============================
# EARTHQUAKE API CONFIGURATION
# ==============================

# FastAPI service name inside Docker
EARTHQUAKE_API=http://earthquake-api:8000

# USGS minimum magnitude filter (optional)
MIN_MAGNITUDE=0.0

# ==============================
# ELASTICSEARCH CONFIGURATION
# ==============================

ES_ENDPOINT=http://elasticsearch:9200

# ==============================
# SCHEDULER CONFIGURATION
# ==============================

# Daily trigger time (HH:MM format)
REQUEST_NEW_DATA_HOURS=02:00

# ==============================
# SPARK CONFIGURATION (optional)
# ==============================

SPARK_MASTER_URL=spark://spark-master:7077